{
  "source": {
    "include": ["backend/src"],
    "includePattern": ".js$",
    "excludePattern": "(node_modules|dist)"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "template": "node_modules/clean-jsdoc-theme"
  },
  "templates": {
    "systemName": "Mindful API Docs",
    "footer": "Generated by JSDoc + clean-jsdoc-theme",
    "includeDate": false
  }
}
